# ─────────────────────────────────────────────────────
# AI 채점 파이프라인 환경변수 템플릿
# 이 파일을 복사해서 .env 로 저장 후 실제 키를 입력하세요.
# .env 파일은 절대 git에 커밋하지 마세요.
# ─────────────────────────────────────────────────────

# Anthropic (필수 — Node 1, Node 3, Aggregator, Debate)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (선택 — GPT 평가 모델 활성화)
OPENAI_API_KEY=sk-...

# Google (선택 — Gemini 평가 모델 활성화)
GOOGLE_API_KEY=AIza...
